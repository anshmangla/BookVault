<%- include("partials/header") %>

    <div class="card p-4 shadow">

        <h2 class="mb-4">
            Add Book
        </h2>

        <form action="/add" method="POST">

            <div class="text-center mb-3">

                <img
                  id="bookPreview"
                  style="
                    max-height:250px;
                    display:none;
                  ">
              
              </div>

            <div class="mb-3">
                <label class="form-label">
                    Title
                </label>

                <input
                    id="title"
                    type="text"
                    name="title"
                    class="form-control"
                    required
                >
            </div>

            <div class="mb-3">
                <label class="form-label">
                    Author
                </label>

                <input
                    id="author"
                    type="text"
                    name="author"
                    class="form-control"
                >
            </div>

            <div class="mb-3">
                <label class="form-label">
                    ISBN
                </label>

                <input
                    id="isbn"
                    type="text"
                    name="isbn"
                    class="form-control"
                >
                <input
                    id="publish_year"
                    type="hidden"
                    name="publish_year"
                >
            </div>

            <div class="mb-3">
                <label class="form-label">
                    Rating (1-10)
                </label>

                <input
                    type="number"
                    name="rating"
                    min="1"
                    max="10"
                    class="form-control"
                >
            </div>

            <div class="mb-3">

                <label class="form-label">
                    Date Read
                </label>

                <input
                    type="date"
                    name="date_read"
                    class="form-control"
                >

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Notes
                </label>

                <textarea
                    name="notes"
                    rows="4"
                    class="form-control"
                ></textarea>

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Review
                </label>

                <textarea
                    name="review"
                    rows="5"
                    class="form-control"
                ></textarea>

            </div>

            <button class="btn btn-success">
                Save Book
            </button>

            <a href="/" class="btn btn-secondary">
                Cancel
            </a>

        </form>

    </div>

    <script>

        const book =
        JSON.parse(
        localStorage.getItem(
            "selectedBook"
        )
        );

        if(book){

        document.getElementById(
            "title"
        ).value =
            book.title || "";

        document.getElementById(
            "author"
        ).value =
            book.author || "";

        document.getElementById(
            "isbn"
        ).value =
            book.isbn || "";

        document.getElementById(
            "publish_year"
        ).value =
            book.publish_year || "";

        const preview =
            document.getElementById(
            "bookPreview"
            );

        if(book.cover_url){

            preview.src =
            book.cover_url;

            preview.style.display =
            "block";

        }

        }
        
        </script>

<%- include("partials/footer") %>

