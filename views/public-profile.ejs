<%- include("partials/header") %>

<main class="library-page">

  <section class="hero-section" style="padding: 3rem 1rem;">
    <div class="hero-inner" style="align-items: center; text-align: center;">
      <% if (profileUser.avatar_url) { %>
        <img src="<%= profileUser.avatar_url %>" alt="<%= profileUser.username %>'s avatar" style="width: 96px; height: 96px; border-radius: 50%; object-fit: cover; margin-bottom: 1rem; border: 2px solid var(--border);">
      <% } else { %>
        <div style="width: 96px; height: 96px; border-radius: 50%; background: var(--primary-soft); color: var(--primary); display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem auto;">
          <i data-lucide="user" style="width: 40px; height: 40px;"></i>
        </div>
      <% } %>
      <h1 class="hero-title" style="font-size: 2rem;"><%= profileUser.username %>'s Library</h1>
      <% if (profileUser.bio) { %>
        <p class="hero-description" style="max-width: 600px;"><%= profileUser.bio %></p>
      <% } %>
      <div style="display: flex; justify-content: center; align-items: center; gap: 3rem; margin-top: 2rem; flex-wrap: wrap; padding-top: 2rem; border-top: 1px solid var(--border);">
        
        <div style="display: flex; flex-direction: column; align-items: center; gap: 0.35rem;">
          <div style="display: flex; align-items: center; gap: 0.5rem; color: var(--text);">
            <i data-lucide="library-big" style="width: 20px; height: 20px; color: var(--primary);"></i>
            <strong style="font-size: 1.25rem;"><%= totalBooks %></strong>
          </div>
          <span style="font-size: 0.85rem; color: var(--text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;"><%= totalBooks === 1 ? "Book" : "Books" %></span>
        </div>

        <div style="display: flex; flex-direction: column; align-items: center; gap: 0.35rem;">
          <div style="display: flex; align-items: center; gap: 0.5rem; color: var(--text);">
            <i data-lucide="star" style="width: 20px; height: 20px; color: var(--primary);"></i>
            <strong style="font-size: 1.25rem;"><%= avgRating %></strong>
          </div>
          <span style="font-size: 0.85rem; color: var(--text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">Avg rating</span>
        </div>

        <a href="/u/<%= profileUser.username %>/followers" style="display: flex; flex-direction: column; align-items: center; gap: 0.35rem; text-decoration: none; cursor: pointer; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
          <div style="display: flex; align-items: center; gap: 0.5rem; color: var(--text);">
            <i data-lucide="users" style="width: 20px; height: 20px; color: var(--primary);"></i>
            <strong style="font-size: 1.25rem;" id="followersCount"><%= followersCount %></strong>
          </div>
          <span style="font-size: 0.85rem; color: var(--text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">Followers</span>
        </a>

        <a href="/u/<%= profileUser.username %>/following" style="display: flex; flex-direction: column; align-items: center; gap: 0.35rem; text-decoration: none; cursor: pointer; transition: opacity 0.2s;" onmouseover="this.style.opacity='0.8'" onmouseout="this.style.opacity='1'">
          <div style="display: flex; align-items: center; gap: 0.5rem; color: var(--text);">
            <i data-lucide="user-plus" style="width: 20px; height: 20px; color: var(--primary);"></i>
            <strong style="font-size: 1.25rem;"><%= followingCount %></strong>
          </div>
          <span style="font-size: 0.85rem; color: var(--text-light); text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600;">Following</span>
        </a>

      </div>
      
      <% if (userId && userId !== profileUser.id) { %>
        <div style="margin-top: 1.5rem;">
          <button id="followBtn" class="btn <%= isFollowing ? 'btn-secondary' : 'btn-primary' %>" data-username="<%= profileUser.username %>">
            <i data-lucide="<%= isFollowing ? 'user-minus' : 'user-plus' %>" aria-hidden="true"></i>
            <span><%= isFollowing ? 'Unfollow' : 'Follow' %></span>
          </button>
        </div>
      <% } %>
    </div>
  </section>

  <script>
    const followBtn = document.getElementById("followBtn");
    if (followBtn) {
      followBtn.addEventListener("click", async () => {
        const username = followBtn.getAttribute("data-username");
        const res = await fetch(`/u/${username}/follow`, { method: "POST" });
        if (res.ok) {
          const data = await res.json();
          const followersCountEl = document.getElementById("followersCount");
          const btnSpan = followBtn.querySelector("span");
          const icon = followBtn.querySelector("i");
          
          if (data.is_following) {
            followBtn.classList.replace("btn-primary", "btn-secondary");
            btnSpan.textContent = "Unfollow";
            icon.setAttribute("data-lucide", "user-minus");
            followersCountEl.textContent = parseInt(followersCountEl.textContent, 10) + 1;
          } else {
            followBtn.classList.replace("btn-secondary", "btn-primary");
            btnSpan.textContent = "Follow";
            icon.setAttribute("data-lucide", "user-plus");
            followersCountEl.textContent = parseInt(followersCountEl.textContent, 10) - 1;
          }
          lucide.createIcons();
        }
      });
    }
  </script>

  <section class="library-section">
    <div class="library-section-head">
      <div>
        <p class="library-section-kicker">Collection</p>
        <h2 class="library-heading">Public Books</h2>
      </div>
    </div>

    <% if (books.length === 0) { %>
      <%- include("partials/empty-state", {
        icon: "library-big",
        title: "No public books",
        description: "This user hasn't added any public books to their library yet.",
        actionHref: null
      }) %>
    <% } else { %>
      <div class="row book-grid">
        <% books.forEach((book, index) => { %>
          <div class="col-xl-3 col-lg-4 col-md-6 mb-4">
            <article class="book-card h-100" style="--stagger:<%= index %>">
              <a href="/u/<%= profileUser.username %>/review/<%= book.id %>" class="book-card-link">
                <div class="cover-container">
                  <% if (book.cover_url) { %>
                    <img src="<%= book.cover_url %>" class="book-cover" alt="<%= book.title %> cover" loading="lazy">
                  <% } else { %>
                    <div class="cover-placeholder" aria-hidden="true">
                      <i data-lucide="book-open"></i>
                    </div>
                  <% } %>
                  <% if (book.rating) { %>
                    <span class="book-rating-badge">
                      <i data-lucide="star" aria-hidden="true"></i>
                      <%= book.rating %>/10
                    </span>
                  <% } %>
                </div>
                <div class="book-card-body">
                  <h3 class="book-card-title"><%= book.title %></h3>
                  <p class="book-card-author"><%= book.author || "Unknown author" %></p>
                  <% if (book.review) { %>
                    <% if (book.has_spoilers) { %>
                      <div class="review-preview" style="display:flex;align-items:center;gap:6px;">
                        <i data-lucide="triangle-alert" style="width:13px;height:13px;color:var(--warning);flex-shrink:0;"></i>
                        <span style="font-size:0.75rem;color:var(--text-light);font-style:italic;">Spoiler review — click to view</span>
                      </div>
                    <% } else { %>
                      <div class="review-preview">
                        <p><%= book.review %></p>
                      </div>
                    <% } %>
                  <% } %>
                </div>
              </a>
            </article>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>

</main>

<%- include("partials/footer") %>
