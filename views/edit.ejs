<%- include("partials/header") %>

    <div class="card p-4 shadow">

        <h2 class="mb-4">
            Edit Book
        </h2>

        <form
            action="/edit/<%= book.id %>?_method=PUT"
            method="POST"
        >

            <div class="mb-3">

                <label class="form-label">
                    Title
                </label>

                <input
                    type="text"
                    name="title"
                    class="form-control"
                    value="<%= book.title %>"
                    required
                >

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Author
                </label>

                <input
                    type="text"
                    name="author"
                    class="form-control"
                    value="<%= book.author %>"
                >

            </div>

            <div class="mb-3">

                <label class="form-label">
                    ISBN
                </label>

                <input
                    type="text"
                    name="isbn"
                    class="form-control"
                    value="<%= book.isbn || '' %>"
                >

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Rating
                </label>

                <input
                    type="number"
                    min="1"
                    max="10"
                    name="rating"
                    class="form-control"
                    value="<%= book.rating %>"
                >

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Date Read
                </label>

                <input
                    type="date"
                    name="date_read"
                    class="form-control"
                    value="<%= book.date_read ? book.date_read.toISOString().split('T')[0] : '' %>"
                >

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Notes
                </label>

                <textarea
                    name="notes"
                    rows="4"
                    class="form-control"
                ><%= book.notes %></textarea>

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Review
                </label>

                <textarea
                    name="review"
                    rows="5"
                    class="form-control"
                ><%= book.review %></textarea>

            </div>

            <button class="btn btn-primary">
                Update Book
            </button>

            <a href="/" class="btn btn-secondary">
                Cancel
            </a>

        </form>

    </div>

<%- include("partials/footer") %>