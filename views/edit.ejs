<%- include("partials/header") %>

<main class="page-shell">

  <%- include("partials/page-header", {
    eyebrow: "Library",
    icon: "pencil",
    title: "Edit book",
    description: `Update the details and reading notes for ${book.title}.`
  }) %>

  <%- include("partials/action-toast") %>

  <section class="surface-card form-card" aria-label="Edit book details">

    <form
      action="/edit/<%= book.id %>?_method=PUT"
      method="POST">

      <% if (book.google_volume_id) { %>
        <section class="imported-metadata" aria-labelledby="imported-metadata-title">
          <div class="imported-metadata-heading">
            <i data-lucide="database" aria-hidden="true"></i>
            <div>
              <h2 id="imported-metadata-title">Google Books metadata</h2>
              <p>
                Imported details stay attached when you update your reading information.
              </p>
            </div>
          </div>

          <dl>
            <% if (book.subtitle) { %>
              <div>
                <dt>Subtitle</dt>
                <dd><%= book.subtitle %></dd>
              </div>
            <% } %>
            <% if (book.publisher) { %>
              <div>
                <dt>Publisher</dt>
                <dd><%= book.publisher %></dd>
              </div>
            <% } %>
            <% if (book.published_date) { %>
              <div>
                <dt>Published</dt>
                <dd><%= book.published_date %></dd>
              </div>
            <% } %>
            <% if (book.page_count) { %>
              <div>
                <dt>Length</dt>
                <dd><%= book.page_count %> pages</dd>
              </div>
            <% } %>
            <% if (book.language) { %>
              <div>
                <dt>Language</dt>
                <dd><%= book.language.toUpperCase() %></dd>
              </div>
            <% } %>
          </dl>
        </section>
      <% } %>

      <section class="form-section" aria-labelledby="book-information">
        <h2 class="form-section-title" id="book-information">
          Book basics
        </h2>

        <%- include("partials/form-field", {
          label: "Title",
          name: "title",
          value: book.title,
          fieldRequired: true
        }) %>

        <%- include("partials/form-field", {
          label: "Author",
          name: "author",
          value: book.author || ""
        }) %>

        <%- include("partials/form-field", {
          label: "ISBN",
          name: "isbn",
          value: book.isbn || "",
          helpText: "ISBN-10 or ISBN-13"
        }) %>

        <%- include("partials/form-field", {
          label: "Publication year",
          name: "publish_year",
          type: "number",
          value: book.publish_year || "",
          min: 1,
          max: new Date().getFullYear() + 1
        }) %>

        <div class="form-field">
          <label class="form-label" for="tags">Tags</label>
          <input
            type="text"
            id="tags"
            name="tags"
            class="form-control"
            value="<%= (bookTags || []).join(', ') %>"
            placeholder="sci-fi, favorites, summer-read"
            autocomplete="off">
          <small class="tag-input-help">Separate tags with commas. Letters, numbers, hyphens and # only.</small>
        </div>
      </section>

      <section class="form-section" aria-labelledby="reading-details">
        <h2 class="form-section-title" id="reading-details">
          Reading details
        </h2>

        <%- include("partials/form-field", {
          label: "Rating",
          name: "rating",
          type: "number",
          value: book.rating || "",
          min: 1,
          max: 10,
          helpText: "Choose a rating from 1 to 10."
        }) %>

        <%- include("partials/form-field", {
          label: "Date read",
          name: "date_read",
          type: "date",
          value: book.date_read
            ? new Date(book.date_read).toISOString().split("T")[0]
            : ""
        }) %>
      </section>

      <section class="form-section" aria-labelledby="your-thoughts">
        <h2 class="form-section-title" id="your-thoughts">
          Your thoughts
        </h2>

        <%- include("partials/form-field", {
          label: "Private notes",
          name: "notes",
          type: "textarea",
          rows: 6,
          value: book.notes || ""
        }) %>

        <%- include("partials/form-field", {
          label: "Review",
          name: "review",
          type: "textarea",
          rows: 8,
          value: book.review || ""
        }) %>

        <div class="form-field">
          <div class="form-check" style="margin-bottom: 1.5rem;">
            <input
              class="form-check-input"
              type="checkbox"
              id="has_spoilers"
              name="has_spoilers"
              <%= book.has_spoilers ? 'checked' : '' %>>
            <label class="form-check-label" for="has_spoilers">
              This review contains spoilers
            </label>
          </div>

          <div class="form-field">
            <label class="form-label" for="visibility">Visibility</label>
            <select class="form-control" id="visibility" name="visibility">
              <option value="public" <%= (!book.visibility || book.visibility === 'public') ? 'selected' : '' %>>Public (Shows on your public profile if active)</option>
              <option value="private" <%= book.visibility === 'private' ? 'selected' : '' %>>Private (Only visible to you)</option>
            </select>
          </div>
        </div>
      </section>

      <div class="form-actions">
        <button class="btn btn-primary" type="submit">
          <i data-lucide="check" aria-hidden="true"></i>
          Update Book
        </button>

        <a href="/book/<%= book.id %>" class="btn btn-secondary">
          Cancel
        </a>
      </div>

    </form>

  </section>

</main>

<%- include("partials/footer") %>
