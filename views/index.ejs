<%- include("partials/header") %>

<div class="hero shadow-sm">

  <h1>
    My Reading Library
  </h1>

  <p class="text-muted">
    Track books, notes and reviews.
  </p>

</div>

<div class="row mb-4">

  <div class="col-md-4">

    <div class="card stats-card shadow-sm">

      <div class="card-body">

        <h5>Total Books</h5>

        <h2><%= totalBooks %></h2>

      </div>

    </div>

  </div>

  <div class="col-md-4">

    <div class="card stats-card shadow-sm">

      <div class="card-body">

        <h5>Average Rating</h5>

        <h2>⭐ <%= avgRating %></h2>

      </div>

    </div>

  </div>

  <div class="col-md-4">

    <div class="card stats-card shadow-sm">

      <div class="card-body">

        <h5>Top Book</h5>

        <p>
          <%= topBook
          ? topBook.title
          : "No books yet" %>
        </p>

      </div>

    </div>

  </div>

</div>

<div class="row mb-4">

  <div class="col-md-6">

    <form action="/search"
          method="GET">

      <div class="input-group">

        <div class="position-relative">

          <input
            type="text"
            id="searchInput"
            class="form-control"
            placeholder="Search title or author"
            name="q"
            autocomplete="off">
        
          <div
            id="searchSuggestions"
            class="list-group position-absolute w-100"
            style="
              z-index:1000;
              display:none;
            ">
          </div>
        
        </div>

        <button
          class="btn btn-dark">
          Search
        </button>

      </div>

    </form>

  </div>

  <div class="col-md-6 text-end">

    <a href="/"
       class="btn btn-secondary">
      All
    </a>

    <a href="/?sort=rating"
       class="btn btn-success">
      Rating
    </a>

    <a href="/?sort=recent"
       class="btn btn-primary">
      Recent
    </a>

  </div>

</div>

<div class="row">

<% if (books.length === 0) { %>

  <div class="text-center">

    <h3>No Books Yet</h3>

    <p>
      Start building your library.
    </p>

  </div>

<% } %>

<% books.forEach(book => { %>

  <div class="col-lg-4 col-md-6 mb-4">
  
    <div class="card shadow-sm book-card h-100">
  
      <a
        href="/book/<%= book.id %>"
        style="text-decoration:none;color:inherit;"
      >
  
        <% if(book.cover_url){ %>
  
        <div class="cover-container">
  
          <img
            src="<%= book.cover_url %>"
            class="book-cover"
            alt="<%= book.title %>"
          >
  
        </div>
  
        <% } %>
  
        <div class="card-body">
  
          <h5>
            <%= book.title %>
          </h5>
  
          <p class="text-muted">
            <%= book.author %>
          </p>
  
          <p>
            ⭐ <%= book.rating || "N/A" %>
          </p>
  
          <div class="review-preview">
  
            <p>
  
              <%= book.review
              ? book.review.substring(0,100)
              : "" %>
  
            </p>
  
          </div>
  
        </div>
  
      </a>
  
      <div class="card-footer d-flex justify-content-between">
  
        <a
          href="/edit/<%= book.id %>"
          class="btn btn-warning"
        >
          Edit
        </a>
  
        <form
          action="/delete/<%= book.id %>?_method=DELETE"
          method="POST"
        >
  
          <button
            class="btn btn-danger"
          >
            Delete
          </button>
  
        </form>
  
      </div>
  
    </div>
  
  </div>
  
  <% }) %>

</div>

<script>

  const searchInput =
    document.getElementById(
      "searchInput"
    );
  
  const suggestions =
    document.getElementById(
      "searchSuggestions"
    );
  
  searchInput.addEventListener(
    "input",
    async () => {
  
      const query =
        searchInput.value.trim();
  
      if(query.length < 2){
  
        suggestions.style.display =
          "none";
  
        return;
  
      }
  
      const response =
        await fetch(
          `/api/search-books?q=${query}`
        );
  
      const books =
        await response.json();
  
      suggestions.innerHTML = "";
  
      if(
        books.length === 0
      ){
  
        suggestions.style.display =
          "none";
  
        return;
  
      }
  
      books.forEach(book => {
  
        const item =
          document.createElement(
            "a"
          );
  
        item.href =
          `/book/${book.id}`;
  
        item.className =
          "list-group-item list-group-item-action";
  
        item.innerHTML =
          `
          <strong>
            ${book.title}
          </strong>
          <br>
          <small>
            ${book.author || ""}
          </small>
          `;
  
        suggestions.appendChild(
          item
        );
  
      });
  
      suggestions.style.display =
        "block";
  
    }
  );
  
  document.addEventListener(
    "click",
    (e)=>{
  
      if(
        !searchInput.contains(e.target)
        &&
        !suggestions.contains(e.target)
      ){
  
        suggestions.style.display =
          "none";
  
      }
  
    }
  );
  
  </script>

<%- include("partials/footer") %>