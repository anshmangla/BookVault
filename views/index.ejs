<%
  const hasFilters =
    Boolean(filters.q) ||
    filters.rating !== "all" ||
    Boolean(filters.year) ||
    Boolean(selectedTag) ||
    Boolean(filters.favorites);
  const resultStart =
    totalResults > 0
      ? (
          pagination.currentPage - 1
        ) * pagination.pageSize + 1
      : 0;
  const resultEnd =
    Math.min(
      pagination.currentPage *
        pagination.pageSize,
      totalResults
    );

  function libraryUrl(overrides = {}) {
    const state = {
      q: filters.q,
      sort: filters.sort,
      rating: filters.rating,
      year: filters.year || "",
      page: filters.page,
      favorites: filters.favorites || "",
      status: filters.status || "",
      ...overrides
    };
    const params =
      new URLSearchParams();

    if (state.q) {
      params.set("q", state.q);
    }
    if (
      state.sort &&
      state.sort !== "newest"
    ) {
      params.set("sort", state.sort);
    }
    if (
      state.rating &&
      state.rating !== "all"
    ) {
      params.set("rating", state.rating);
    }
    if (state.year) {
      params.set("year", state.year);
    }
    if (state.favorites) {
      params.set("favorites", "1");
    }
    if (
      state.status &&
      state.status !== "all"
    ) {
      params.set("status", state.status);
    }
    if (state.page && state.page > 1) {
      params.set("page", state.page);
    }

    const query = params.toString();
    return query ? `/?${query}` : "/";
  }

  function formatBookDate(value) {
    return new Date(value).toLocaleDateString(
      undefined,
      {
        month: "short",
        year: "numeric"
      }
    );
  }
%>

<%- include("partials/header") %>

<main class="library-page">

  <%- include("partials/action-toast") %>

  <% if (totalBooks === 0) { %>

    <section class="hero-section hero-section-onboarding" aria-label="Welcome">

      <div class="hero-glow" aria-hidden="true"></div>

      <div class="hero-inner">
        <div class="hero-content">
          <span class="badge-soft hero-greeting">
            <i data-lucide="sparkles" aria-hidden="true"></i>
            <%= greeting %>, <%= userName || "Reader" %>
          </span>

          <h1 class="hero-title">
            Build your
            <span class="text-gradient">digital bookshelf</span>
          </h1>

          <p class="hero-description">
            Keep every book, rating, note, and review together in a library that grows with you.
          </p>

          <div class="hero-actions">
            <a href="/search-book" class="btn btn-primary btn-hero">
              <i data-lucide="plus" aria-hidden="true"></i>
              Add Your First Book
            </a>
          </div>
        </div>
      </div>

    </section>

  <% } else { %>

    <section class="library-overview" aria-labelledby="library-title">

      <div class="library-overview-copy">
        <span class="badge-soft">
          <i data-lucide="sparkles" aria-hidden="true"></i>
          <%= greeting %>, <%= userName || "Reader" %>
        </span>

        <h1 id="library-title">My library</h1>

        <p>
          Your books, reading history, and notes in one place.
        </p>
      </div>

      <a href="/search-book" class="btn btn-primary">
        <i data-lucide="plus" aria-hidden="true"></i>
        Add Book
      </a>

      <div class="library-overview-stats" aria-label="Library statistics">
        <div>
          <i data-lucide="library-big" aria-hidden="true"></i>
          <strong><%= totalBooks %></strong>
          <span><%= totalBooks === 1 ? "Book" : "Books" %></span>
        </div>

        <div>
          <i data-lucide="star" aria-hidden="true"></i>
          <strong><%= avgRating %></strong>
          <span>Average rating</span>
        </div>

        <div>
          <i data-lucide="trophy" aria-hidden="true"></i>
          <strong><%= topBook ? topBook.title : "Not rated" %></strong>
          <span>Highest rated</span>
        </div>
      </div>

    </section>

  <% } %>

  <section class="library-section" aria-labelledby="books-heading">

    <div class="library-section-head">
      <div>
        <p class="library-section-kicker">Collection</p>
        <h2 id="books-heading" class="library-heading">
          <% if (filters.favorites) { %>
            Favorites
          <% } else if (filters.q) { %>
            Results for “<%= filters.q %>”
          <% } else { %>
            Books
          <% } %>
        </h2>
      </div>

      <% if (hasFilters) { %>
        <a href="/" class="btn btn-light btn-compact">
          <i data-lucide="x" aria-hidden="true"></i>
          Clear Filters
        </a>
      <% } %>

      <a
        href="<%= libraryUrl({ favorites: filters.favorites ? '' : '1', page: 1 }) %>"
        class="btn btn-compact<%= filters.favorites ? ' btn-primary' : ' btn-light' %>">
        <i data-lucide="heart" aria-hidden="true"></i>
        <%= filters.favorites ? 'Showing Favorites' : 'Favorites' %>
      </a>
    </div>

    <% if (totalBooks > 0 || (filters.status && filters.status !== "all")) { %>
      <div class="connections-tabs" style="display: flex; gap: 2rem; margin-bottom: 2rem; border-bottom: 1px solid var(--border); overflow-x: auto; white-space: nowrap;">
        <a href="<%= libraryUrl({ status: 'all', page: 1 }) %>" 
           style="padding: 1rem 0; text-decoration: none; font-weight: 600; color: <%= (!filters.status || filters.status === 'all') ? 'var(--primary)' : 'var(--text-light)' %>; border-bottom: 3px solid <%= (!filters.status || filters.status === 'all') ? 'var(--primary)' : 'transparent' %>;">
          All Books
        </a>
        <a href="<%= libraryUrl({ status: 'read', page: 1 }) %>" 
           style="padding: 1rem 0; text-decoration: none; font-weight: 600; color: <%= filters.status === 'read' ? 'var(--primary)' : 'var(--text-light)' %>; border-bottom: 3px solid <%= filters.status === 'read' ? 'var(--primary)' : 'transparent' %>;">
          Read
        </a>
        <a href="<%= libraryUrl({ status: 'currently_reading', page: 1 }) %>" 
           style="padding: 1rem 0; text-decoration: none; font-weight: 600; color: <%= filters.status === 'currently_reading' ? 'var(--primary)' : 'var(--text-light)' %>; border-bottom: 3px solid <%= filters.status === 'currently_reading' ? 'var(--primary)' : 'transparent' %>;">
          Currently Reading
        </a>
        <a href="<%= libraryUrl({ status: 'want_to_read', page: 1 }) %>" 
           style="padding: 1rem 0; text-decoration: none; font-weight: 600; color: <%= filters.status === 'want_to_read' ? 'var(--primary)' : 'var(--text-light)' %>; border-bottom: 3px solid <%= filters.status === 'want_to_read' ? 'var(--primary)' : 'transparent' %>;">
          Want to Read
        </a>
        <a href="<%= libraryUrl({ status: 'dnf', page: 1 }) %>" 
           style="padding: 1rem 0; text-decoration: none; font-weight: 600; color: <%= filters.status === 'dnf' ? 'var(--primary)' : 'var(--text-light)' %>; border-bottom: 3px solid <%= filters.status === 'dnf' ? 'var(--primary)' : 'transparent' %>;">
          Did Not Finish
        </a>
      </div>
    <% } %>

    <% if (totalBooks > 0) { %>

      <form action="/" method="GET" class="library-controls" role="search">

        <div class="library-search">
          <label for="searchInput" class="visually-hidden">
            Search your library by title, author, or ISBN
          </label>

          <div class="search-bar-inner">
            <span class="search-bar-icon" aria-hidden="true">
              <i data-lucide="search"></i>
            </span>

            <input
              type="search"
              id="searchInput"
              class="search-bar-input"
              placeholder="Search title, author, or ISBN"
              name="q"
              value="<%= filters.q %>"
              autocomplete="off"
              aria-autocomplete="list"
              aria-controls="searchSuggestions"
              aria-expanded="false">

            <% if (filters.q) { %>
              <a
                href="<%= libraryUrl({ q: "", page: 1 }) %>"
                class="search-clear"
                aria-label="Clear search">
                <i data-lucide="x" aria-hidden="true"></i>
              </a>
            <% } %>

            <div
              id="searchSuggestions"
              class="search-suggestions"
              role="listbox"
              hidden>
            </div>
          </div>
        </div>

        <div class="library-control">
          <label for="sort">Sort</label>
          <select id="sort" name="sort" class="form-select">
            <option value="newest" <%= filters.sort === "newest" ? "selected" : "" %>>
              Recently added
            </option>
            <option value="recent" <%= filters.sort === "recent" ? "selected" : "" %>>
              Recently read
            </option>
            <option value="rating" <%= filters.sort === "rating" ? "selected" : "" %>>
              Highest rated
            </option>
            <option value="title" <%= filters.sort === "title" ? "selected" : "" %>>
              Title A–Z
            </option>
            <option value="author" <%= filters.sort === "author" ? "selected" : "" %>>
              Author A–Z
            </option>
          </select>
        </div>

        <div class="library-control">
          <label for="ratingFilter">Rating</label>
          <select id="ratingFilter" name="rating" class="form-select">
            <option value="all" <%= filters.rating === "all" ? "selected" : "" %>>
              All books
            </option>
            <option value="rated" <%= filters.rating === "rated" ? "selected" : "" %>>
              Rated
            </option>
            <option value="unrated" <%= filters.rating === "unrated" ? "selected" : "" %>>
              Unrated
            </option>
          </select>
        </div>

        <div class="library-control">
          <label for="yearFilter">Read in</label>
          <select id="yearFilter" name="year" class="form-select">
            <option value="">Any year</option>
            <% availableYears.forEach(year => { %>
              <option
                value="<%= year %>"
                <%= filters.year === year ? "selected" : "" %>>
                <%= year %>
              </option>
            <% }) %>
          </select>
        </div>

        <button type="submit" class="btn btn-primary library-apply">
          Apply
        </button>

      </form>

      <% if (userTags && userTags.length) { %>
        <div class="tag-filter-bar" aria-label="Filter by tag">
          <span class="tag-filter-bar-label">Tags:</span>
          <% userTags.forEach(tag => { %>
            <a
              href="/?tag=<%= encodeURIComponent(tag) %><%= filters.q ? `&q=${encodeURIComponent(filters.q)}` : '' %>"
              class="tag-filter-pill<%= selectedTag === tag ? ' active' : '' %>"
              aria-current="<%= selectedTag === tag ? 'true' : 'false' %>">
              #<%= tag %>
            </a>
          <% }) %>
          <% if (selectedTag) { %>
            <a href="/" class="tag-filter-pill" style="margin-left: auto;">
              <i data-lucide="x" aria-hidden="true" style="width:12px;height:12px;"></i>
              Clear tag
            </a>
          <% } %>
        </div>
      <% } %>

      <div class="library-results-summary" aria-live="polite">
        <% if (totalResults > 0) { %>
          Showing <strong><%= resultStart %>–<%= resultEnd %></strong>
          of <strong><%= totalResults %></strong>
          <%= totalResults === 1 ? "book" : "books" %>
        <% } else { %>
          No books match these filters
        <% } %>
      </div>

    <% } %>

    <% if (totalBooks === 0) { %>

      <%- include("partials/empty-state", {
        icon: "library-big",
        title: "Your library is ready",
        description: "Add your first book from Google Books or enter it manually.",
        actionHref: "/search-book",
        actionLabel: "Add Your First Book",
        actionIcon: "plus"
      }) %>

    <% } else if (books.length === 0) { %>

      <%- include("partials/empty-state", {
        icon: "search-x",
        title: "No matching books",
        description: filters.q
          ? `Nothing in your library matches “${filters.q}”. Try another search or clear the filters.`
          : "Try changing or clearing your current filters.",
        actionHref: "/",
        actionLabel: "Clear Filters",
        actionIcon: "x"
      }) %>

    <% } else { %>

      <div class="row book-grid">

        <% books.forEach((book, index) => { %>

          <div class="col-xl-3 col-lg-4 col-md-6 mb-4">

            <article class="book-card h-100" style="--stagger:<%= index %>">

              <a href="/book/<%= book.id %>" class="book-card-link">

                <div class="cover-container">
                  <% if (book.cover_url) { %>
                    <img
                      src="<%= book.cover_url %>"
                      class="book-cover"
                      alt="<%= book.title %> cover"
                      loading="lazy">
                  <% } else { %>
                    <div class="cover-placeholder" aria-hidden="true">
                      <i data-lucide="book-open"></i>
                    </div>
                  <% } %>

                  <% if (book.rating) { %>
                    <span class="book-rating-badge">
                      <i data-lucide="star" aria-hidden="true"></i>
                      <%= book.rating %>/10
                    </span>
                  <% } %>
                </div>

                <div class="book-card-body">
                  <h3 class="book-card-title"><%= book.title %></h3>
                  <p class="book-card-author">
                    <%= book.author || "Unknown author" %>
                  </p>

                  <div class="book-card-metadata">
                    <% if (book.date_read) { %>
                      <span>
                        <i data-lucide="calendar-check" aria-hidden="true"></i>
                        Read <%= formatBookDate(book.date_read) %>
                      </span>
                    <% } else if (book.publish_year) { %>
                      <span>
                        <i data-lucide="calendar" aria-hidden="true"></i>
                        Published <%= book.publish_year %>
                      </span>
                    <% } else { %>
                      <span>
                        <i data-lucide="bookmark" aria-hidden="true"></i>
                        In your library
                      </span>
                    <% } %>
                  </div>

                  <% if (book.review) { %>
                    <% if (book.has_spoilers) { %>
                      <div class="review-preview" style="display:flex;align-items:center;gap:6px;">
                        <i data-lucide="triangle-alert" style="width:13px;height:13px;color:var(--warning);flex-shrink:0;"></i>
                        <span style="font-size:0.75rem;color:var(--text-light);font-style:italic;">Spoiler review — view on details page</span>
                      </div>
                    <% } else { %>
                      <div class="review-preview">
                        <p><%= book.review %></p>
                      </div>
                    <% } %>
                  <% } %>

                  <% if (book.tags && book.tags.length) { %>
                    <div class="book-tag-list" aria-label="Tags">
                      <% book.tags.forEach(tag => { %>
                        <span class="tag-pill">#<%= tag %></span>
                      <% }) %>
                    </div>
                  <% } %>
                </div>

              </a>

              <div class="book-card-footer">
                <span>
                  <%= book.google_volume_id ? "Google Books" : "Manual entry" %>
                </span>

                <div style="display:flex;align-items:center;gap:4px;">
                  <button
                    type="button"
                    class="btn-favorite-card<%= book.is_favorite ? ' is-favorite' : '' %>"
                    data-book-id="<%= book.id %>"
                    aria-label="<%= book.is_favorite ? 'Remove from favorites' : 'Add to favorites' %>"
                    aria-pressed="<%= book.is_favorite ? 'true' : 'false' %>">
                    <i data-lucide="heart" aria-hidden="true"></i>
                  </button>

                  <div class="dropdown">
                    <button
                      class="btn btn-card-menu"
                      type="button"
                      data-bs-toggle="dropdown"
                      aria-expanded="false"
                      aria-label="Manage <%= book.title %>">
                      <i data-lucide="ellipsis" aria-hidden="true"></i>
                    </button>

                    <ul class="dropdown-menu dropdown-menu-end">
                      <li>
                        <a class="dropdown-item" href="/book/<%= book.id %>">
                          <i data-lucide="eye" aria-hidden="true"></i>
                          View Details
                        </a>
                      </li>
                      <li>
                        <a class="dropdown-item" href="/edit/<%= book.id %>">
                          <i data-lucide="pencil" aria-hidden="true"></i>
                          Edit
                        </a>
                      </li>
                      <li><hr class="dropdown-divider"></li>
                      <li>
                        <form
                          action="/delete/<%= book.id %>?_method=DELETE"
                          method="POST"
                          data-confirm-form
                          data-confirm-title="Delete book?"
                          data-confirm-message="Remove &quot;<%= book.title %>&quot; from your library? You can undo this from the next screen."
                          data-confirm-label="Remove Book">
                          <button type="submit" class="dropdown-item text-danger">
                            <i data-lucide="trash-2" aria-hidden="true"></i>
                            Delete
                          </button>
                        </form>
                      </li>
                    </ul>
                  </div>
                </div>

              </div>

            </article>

          </div>

        <% }) %>

      </div>

      <% if (pagination.totalPages > 1) { %>
        <nav class="library-pagination" aria-label="Library pages">
          <a
            href="<%= libraryUrl({ page: pagination.currentPage - 1 }) %>"
            class="pagination-link<%= pagination.currentPage === 1 ? " disabled" : "" %>"
            <%= pagination.currentPage === 1 ? 'aria-disabled="true" tabindex="-1"' : "" %>>
            <i data-lucide="chevron-left" aria-hidden="true"></i>
            Previous
          </a>

          <div class="pagination-pages">
            <%
              const firstPage =
                Math.max(
                  1,
                  pagination.currentPage - 2
                );
              const lastPage =
                Math.min(
                  pagination.totalPages,
                  firstPage + 4
                );
            %>

            <% for (let page = firstPage; page <= lastPage; page += 1) { %>
              <a
                href="<%= libraryUrl({ page }) %>"
                class="pagination-number<%= page === pagination.currentPage ? " active" : "" %>"
                <%= page === pagination.currentPage ? 'aria-current="page"' : "" %>>
                <%= page %>
              </a>
            <% } %>
          </div>

          <a
            href="<%= libraryUrl({ page: pagination.currentPage + 1 }) %>"
            class="pagination-link<%= pagination.currentPage === pagination.totalPages ? " disabled" : "" %>"
            <%= pagination.currentPage === pagination.totalPages ? 'aria-disabled="true" tabindex="-1"' : "" %>>
            Next
            <i data-lucide="chevron-right" aria-hidden="true"></i>
          </a>
        </nav>
      <% } %>

    <% } %>

  </section>

</main>

<script>
  // Favorite toggle on library cards
  document.querySelectorAll(".btn-favorite-card").forEach(btn => {
    btn.addEventListener("click", async (e) => {
      e.stopPropagation(); // prevent card link navigation
      const bookId = btn.dataset.bookId;
      try {
        const res = await fetch(`/book/${bookId}/favorite`, {
          method: "POST",
          headers: { "Content-Type": "application/json" }
        });
        if (!res.ok) throw new Error("Failed");
        const data = await res.json();
        const isFav = data.is_favorite;
        btn.classList.toggle("is-favorite", isFav);
        btn.setAttribute("aria-pressed", String(isFav));
        btn.setAttribute("aria-label", isFav ? "Remove from favorites" : "Add to favorites");
        if (typeof lucide !== "undefined") lucide.createIcons();
      } catch (e) {
        console.error("Favorite toggle failed:", e);
      }
    });
  });

  const searchInput =
    document.getElementById("searchInput");
  const suggestions =
    document.getElementById(
      "searchSuggestions"
    );

  if (searchInput && suggestions) {
    let debounceTimer;
    let requestController;
    let activeIndex = -1;

    function suggestionItems() {
      return Array.from(
        suggestions.querySelectorAll(
          ".search-suggestion-item"
        )
      );
    }

    function setSuggestionsOpen(open) {
      searchInput.setAttribute(
        "aria-expanded",
        open ? "true" : "false"
      );
      suggestions.hidden = !open;

      if (!open) {
        activeIndex = -1;
        searchInput.removeAttribute(
          "aria-activedescendant"
        );
      }
    }

    function setActiveSuggestion(index) {
      const items =
        suggestionItems();

      if (!items.length) {
        return;
      }

      activeIndex =
        (
          index + items.length
        ) % items.length;

      items.forEach((item, itemIndex) => {
        const isActive =
          itemIndex === activeIndex;
        item.classList.toggle(
          "active",
          isActive
        );
        item.setAttribute(
          "aria-selected",
          String(isActive)
        );
      });

      const activeItem =
        items[activeIndex];
      searchInput.setAttribute(
        "aria-activedescendant",
        activeItem.id
      );
      activeItem.scrollIntoView({
        block: "nearest"
      });
    }

    function appendHighlighted(
      element,
      text,
      query
    ) {
      const source =
        String(text || "");
      const matchIndex =
        source
          .toLocaleLowerCase()
          .indexOf(
            query.toLocaleLowerCase()
          );

      if (matchIndex < 0) {
        element.textContent = source;
        return;
      }

      element.append(
        document.createTextNode(
          source.slice(0, matchIndex)
        )
      );

      const mark =
        document.createElement("mark");
      mark.textContent =
        source.slice(
          matchIndex,
          matchIndex + query.length
        );
      element.appendChild(mark);
      element.append(
        document.createTextNode(
          source.slice(
            matchIndex + query.length
          )
        )
      );
    }

    function showSuggestionMessage(message) {
      suggestions.replaceChildren();
      const status =
        document.createElement("div");
      status.className =
        "search-suggestion-empty";
      status.textContent = message;
      suggestions.appendChild(status);
      setSuggestionsOpen(true);
    }

    async function loadSuggestions() {
      const query =
        searchInput.value.trim();

      if (query.length < 2) {
        setSuggestionsOpen(false);
        return;
      }

      requestController?.abort();
      requestController =
        new AbortController();
      showSuggestionMessage("Searching…");

      try {
        const response =
          await fetch(
            `/api/search-books?q=${encodeURIComponent(query)}`,
            {
              signal:
                requestController.signal
            }
          );
        const books =
          await response.json();

        suggestions.replaceChildren();
        activeIndex = -1;

        if (!books.length) {
          showSuggestionMessage(
            "No matching books"
          );
          return;
        }

        books.forEach((book, index) => {
          const item =
            document.createElement("a");
          const title =
            document.createElement("strong");
          const author =
            document.createElement("span");

          item.id =
            `search-option-${index}`;
          item.href =
            `/book/${book.id}`;
          item.className =
            "search-suggestion-item";
          item.setAttribute(
            "role",
            "option"
          );
          item.setAttribute(
            "aria-selected",
            "false"
          );

          appendHighlighted(
            title,
            book.title,
            query
          );
          appendHighlighted(
            author,
            book.author || "",
            query
          );

          item.append(title, author);
          suggestions.appendChild(item);
        });

        setSuggestionsOpen(true);
      } catch (error) {
        if (error.name !== "AbortError") {
          showSuggestionMessage(
            "Suggestions unavailable"
          );
        }
      }
    }

    searchInput.addEventListener(
      "input",
      () => {
        clearTimeout(debounceTimer);
        debounceTimer =
          setTimeout(
            loadSuggestions,
            250
          );
      }
    );

    searchInput.addEventListener(
      "keydown",
      event => {
        const items =
          suggestionItems();

        if (
          event.key === "ArrowDown" &&
          items.length
        ) {
          event.preventDefault();
          setActiveSuggestion(
            activeIndex + 1
          );
        } else if (
          event.key === "ArrowUp" &&
          items.length
        ) {
          event.preventDefault();
          setActiveSuggestion(
            activeIndex - 1
          );
        } else if (
          event.key === "Enter" &&
          activeIndex >= 0
        ) {
          event.preventDefault();
          window.location.assign(
            items[activeIndex].href
          );
        } else if (
          event.key === "Escape"
        ) {
          setSuggestionsOpen(false);
        }
      }
    );

    document.addEventListener(
      "click",
      event => {
        if (
          !searchInput.contains(
            event.target
          ) &&
          !suggestions.contains(
            event.target
          )
        ) {
          setSuggestionsOpen(false);
        }
      }
    );
  }
</script>

<%- include("partials/footer") %>
