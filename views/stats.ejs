<%- include("partials/header") %>

<main class="page-shell">

  <%- include("partials/page-header", {
    eyebrow: "Insights",
    icon: "chart-column",
    title: "Reading analytics",
    description: "A quick snapshot of your library and reading activity.",
    actionHref: "/search-book",
    actionLabel: "Add Book",
    actionIcon: "plus"
  }) %>

  <section class="analytics-summary" aria-label="Reading summary">

    <article class="surface-card analytics-card">
      <span class="analytics-card-icon" aria-hidden="true">
        <i data-lucide="library-big"></i>
      </span>
      <div>
        <p>Total Books</p>
        <strong><%= totalBooks %></strong>
      </div>
    </article>

    <article class="surface-card analytics-card">
      <span class="analytics-card-icon" aria-hidden="true">
        <i data-lucide="star"></i>
      </span>
      <div>
        <p>Average Rating</p>
        <strong><%= avgRating %></strong>
      </div>
    </article>

    <article class="surface-card analytics-card">
      <span class="analytics-card-icon" aria-hidden="true">
        <i data-lucide="calendar-check"></i>
      </span>
      <div>
        <p>Read This Year</p>
        <strong><%= booksThisYear %></strong>
      </div>
    </article>

  </section>

  <% if (books.some(book => book.rating)) { %>

    <section class="surface-card analytics-chart" aria-labelledby="ratings-heading">
      <div class="analytics-chart-header">
        <h2 id="ratings-heading">Book ratings</h2>
        <p>Your ratings across the library.</p>
      </div>

      <div class="analytics-chart-canvas">
        <canvas id="ratingChart">
          A chart showing your book ratings.
        </canvas>
      </div>
    </section>

  <% } else { %>

    <%- include("partials/empty-state", {
      icon: "chart-no-axes-column",
      title: "No rating data yet",
      description: "Rate a book to start building your reading insights.",
      actionHref: "/",
      actionLabel: "View Library",
      actionIcon: "library-big"
    }) %>

  <% } %>

</main>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  const ratings =
    <%- JSON.stringify(
      books
        .filter(book => book.rating)
        .map(book => ({
          title: book.title,
          rating: book.rating
        }))
    ).replace(/</g, "\\u003c") %>;

  const chartCanvas =
    document.getElementById("ratingChart");

  if (chartCanvas) {
    new Chart(chartCanvas, {
      type: "bar",
      data: {
        labels: ratings.map(book => book.title),
        datasets: [{
          label: "Rating",
          data: ratings.map(book => book.rating),
          backgroundColor: "#6366F1",
          borderRadius: 8
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          y: {
            beginAtZero: true,
            max: 10,
            ticks: {
              stepSize: 1
            }
          }
        },
        plugins: {
          legend: {
            display: false
          }
        }
      }
    });
  }
</script>

<%- include("partials/footer") %>
