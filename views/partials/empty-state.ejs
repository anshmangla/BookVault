<div class="empty-state">

  <div class="empty-state-icon" aria-hidden="true">
    <i data-lucide="<%= icon %>"></i>
  </div>

  <h2><%= title %></h2>
  <p><%= description %></p>

  <% if (
    typeof actionHref !== "undefined" &&
    actionHref &&
    typeof actionLabel !== "undefined" &&
    actionLabel
  ) { %>
    <a href="<%= actionHref %>" class="btn btn-primary">
      <% if (typeof actionIcon !== "undefined" && actionIcon) { %>
        <i data-lucide="<%= actionIcon %>" aria-hidden="true"></i>
      <% } %>
      <%= actionLabel %>
    </a>
  <% } %>

</div>
