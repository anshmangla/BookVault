<%
  const resolvedId =
    typeof id !== "undefined" && id
      ? id
      : name;
  const resolvedType =
    typeof type !== "undefined" && type
      ? type
      : "text";
  const resolvedValue =
    typeof value !== "undefined" &&
    value !== null &&
    value !== undefined
      ? value
      : "";
  const isRequired =
    typeof fieldRequired !== "undefined" &&
    fieldRequired;
  const describedBy = [
    typeof helpText !== "undefined" && helpText
      ? `${resolvedId}-help`
      : "",
    typeof fieldError !== "undefined" && fieldError
      ? `${resolvedId}-error`
      : ""
  ].filter(Boolean).join(" ");
%>

<div class="form-field">

  <label class="form-label" for="<%= resolvedId %>">
    <%= label %>
    <% if (isRequired) { %>
      <span class="field-required" aria-hidden="true">*</span>
    <% } %>
  </label>

  <% if (resolvedType === "textarea") { %>

    <textarea
      id="<%= resolvedId %>"
      name="<%= name %>"
      class="form-control"
      rows="<%= typeof rows !== "undefined" ? rows : 4 %>"
      <% if (typeof placeholder !== "undefined" && placeholder) { %>
        placeholder="<%= placeholder %>"
      <% } %>
      <% if (describedBy) { %>
        aria-describedby="<%= describedBy %>"
      <% } %>
      <% if (typeof fieldError !== "undefined" && fieldError) { %>
        aria-invalid="true"
      <% } %>
      <%= isRequired ? "required" : "" %>><%= resolvedValue %></textarea>

  <% } else { %>

    <% if (resolvedType === "password") { %>
      <div class="password-input-wrapper" style="position: relative; display: flex; align-items: center;">
    <% } %>

    <input
      id="<%= resolvedId %>"
      type="<%= resolvedType %>"
      name="<%= name %>"
      class="form-control"
      value="<%= resolvedValue %>"
      <% if (typeof placeholder !== "undefined" && placeholder) { %>
        placeholder="<%= placeholder %>"
      <% } %>
      <% if (typeof autocomplete !== "undefined" && autocomplete) { %>
        autocomplete="<%= autocomplete %>"
      <% } %>
      <% if (typeof min !== "undefined" && min !== null) { %>
        min="<%= min %>"
      <% } %>
      <% if (typeof max !== "undefined" && max !== null) { %>
        max="<%= max %>"
      <% } %>
      <% if (typeof step !== "undefined" && step !== null) { %>
        step="<%= step %>"
      <% } %>
      <% if (describedBy) { %>
        aria-describedby="<%= describedBy %>"
      <% } %>
      <% if (typeof fieldError !== "undefined" && fieldError) { %>
        aria-invalid="true"
      <% } %>
      <%= isRequired ? "required" : "" %>>

    <% if (resolvedType === "password") { %>
        <button
          type="button"
          class="btn btn-password-toggle"
          aria-label="Show password"
          aria-controls="<%= resolvedId %>"
          style="position: absolute; right: 0.5rem; background: none; border: none; padding: 0.25rem; display: flex; align-items: center; color: var(--text-muted);"
        >
          <i data-lucide="eye" aria-hidden="true" style="width: 1.25rem; height: 1.25rem;"></i>
        </button>
      </div>
    <% } %>

  <% } %>

  <% if (typeof helpText !== "undefined" && helpText) { %>
    <small id="<%= resolvedId %>-help" class="field-help">
      <%= helpText %>
    </small>
  <% } %>

  <% if (typeof fieldError !== "undefined" && fieldError) { %>
    <small id="<%= resolvedId %>-error" class="field-error">
      <%= fieldError %>
    </small>
  <% } %>

</div>
