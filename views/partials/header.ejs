<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1">
  <meta name="theme-color" content="#6366F1">

  <title>
    <%= pageTitle === "BookVault" ? "BookVault" : `${pageTitle} · BookVault` %>
  </title>

  <script>
    (() => {
      try {
        const savedTheme =
          localStorage.getItem("theme");

        const prefersDark =
          window.matchMedia(
            "(prefers-color-scheme: dark)"
          ).matches;

        if (
          savedTheme === "dark" ||
          (!savedTheme && prefersDark)
        ) {
          document.documentElement
            .classList.add("dark");
        }
      } catch (error) {
        // Keep the default theme when storage is blocked.
      }
    })();
  </script>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body>

  <nav
    class="navbar navbar-expand-lg modern-navbar"
    aria-label="Primary navigation">

    <div class="container">

      <a
        class="navbar-brand logo"
        href="/"
        aria-label="BookVault home">
        <i data-lucide="library-big" aria-hidden="true"></i>
        <span>BookVault</span>
      </a>

      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbar"
        aria-controls="navbar"
        aria-expanded="false"
        aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbar">

        <% if (userId) { %>

          <ul class="navbar-nav mx-auto">
            <li class="nav-item">
              <a
                class="nav-link<%= currentPath === "/" ? " active" : "" %>"
                href="/"
                <%- currentPath === "/" ? 'aria-current="page"' : "" %>>
                <i data-lucide="house" aria-hidden="true"></i>
                Library
              </a>
            </li>

            <li class="nav-item">
              <a
                class="nav-link<%= currentPath === "/stats" ? " active" : "" %>"
                href="/stats"
                <%- currentPath === "/stats" ? 'aria-current="page"' : "" %>>
                <i data-lucide="chart-column" aria-hidden="true"></i>
                Analytics
              </a>
            </li>

            <li class="nav-item">
              <a
                class="nav-link<%= currentPath === "/search-book" ? " active" : "" %>"
                href="/search-book"
                <%- currentPath === "/search-book" ? 'aria-current="page"' : "" %>>
                <i data-lucide="search" aria-hidden="true"></i>
                Discover
              </a>
            </li>
          </ul>

        <% } else { %>

          <div class="navbar-nav mx-auto"></div>

        <% } %>

        <div class="navbar-actions">

          <% if (userId) { %>

            <a href="/search-book" class="btn btn-light">
              <i data-lucide="plus" aria-hidden="true"></i>
              Add Book
            </a>

          <% } %>

          <button
            id="themeToggle"
            class="btn btn-light theme-toggle"
            type="button"
            aria-label="Use dark theme"
            title="Use dark theme">
            <i data-lucide="moon" aria-hidden="true"></i>
          </button>

          <% if (userId) { %>

            <div class="dropdown">
              <button
                class="btn btn-primary dropdown-toggle"
                type="button"
                data-bs-toggle="dropdown"
                aria-expanded="false">
                <i data-lucide="user" aria-hidden="true"></i>
                <%= userName || "Reader" %>
              </button>

              <ul class="dropdown-menu dropdown-menu-end">
                <li>
                  <a class="dropdown-item" href="/">My Library</a>
                </li>
                <li>
                  <a class="dropdown-item" href="/stats">Analytics</a>
                </li>
                <li>
                  <a class="dropdown-item" href="/settings">Settings</a>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                  <a class="dropdown-item text-danger" href="/logout">
                    Logout
                  </a>
                </li>
              </ul>
            </div>

          <% } else { %>

            <a href="/login" class="btn btn-light">Log in</a>
            <a href="/register" class="btn btn-primary">Create account</a>

          <% } %>

        </div>

      </div>

    </div>

  </nav>

  <div class="container mt-4 fade-up">
