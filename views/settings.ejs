<%- include("partials/header") %>

<main class="page-shell">

  <%- include("partials/page-header", {
    eyebrow: "Settings",
    icon: "settings",
    title: "Your Profile",
    description: "Manage your public profile and privacy settings."
  }) %>

  <%- include("partials/action-toast") %>

  <section class="surface-card form-card" aria-label="Username settings" style="margin-bottom: 2rem;">
    <h2 class="form-section-title">Username</h2>
    
    <% if (userProfile.username_changed) { %>
      <div class="form-field">
        <label class="form-label">Current Username</label>
        <div style="display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1rem; background: var(--surface-hover); border-radius: var(--radius-md); border: 1px solid var(--border); color: var(--text-light);">
          <i data-lucide="lock" aria-hidden="true" style="width: 16px; height: 16px;"></i>
          <span><%= userProfile.username %></span>
        </div>
        <small class="text-muted" style="margin-top: 0.5rem; display: block;">You have already changed your username and it is now locked.</small>
      </div>
    <% } else { %>
      <form action="/settings/username?_method=PUT" method="POST">
        <div class="form-field">
          <label class="form-label" for="username">Choose your Username</label>
          <div style="display: flex; gap: 1rem; align-items: flex-start; flex-wrap: wrap;">
            <div style="flex-grow: 1; min-width: 200px;">
              <input type="text" id="username" name="username" class="form-control" value="<%= userProfile.username %>" required minlength="3" pattern="[a-zA-Z0-9_]+">
              <small class="text-muted" style="margin-top: 0.5rem; display: block; color: var(--warning) !important;">
                <i data-lucide="triangle-alert" style="width: 14px; height: 14px; vertical-align: middle; margin-bottom: 2px;"></i>
                <strong>Warning:</strong> You can only change your username once.
              </small>
            </div>
            <button class="btn btn-primary" type="submit">
              Save Username
            </button>
          </div>
        </div>
      </form>
    <% } %>
  </section>

  <section class="surface-card form-card" aria-label="Profile settings">

    <form action="/settings?_method=PUT" method="POST">

      <section class="form-section" aria-labelledby="profile-visibility">
        <h2 class="form-section-title" id="profile-visibility">
          Profile Visibility
        </h2>

        <div class="form-field">
          <div class="form-check">
            <input
              class="form-check-input"
              type="checkbox"
              id="is_public"
              name="is_public"
              <%= userProfile.is_public ? 'checked' : '' %>>
            <label class="form-check-label" for="is_public">
              <strong>Make my profile public</strong>
              <br>
              <small class="text-muted">If checked, anyone can see your public library at <a href="/u/<%= userProfile.username %>" target="_blank">/u/<%= userProfile.username %></a>.</small>
            </label>
          </div>
        </div>
      </section>

      <section class="form-section" aria-labelledby="profile-details">
        <h2 class="form-section-title" id="profile-details">
          Profile Details
        </h2>

        <%- include("partials/form-field", {
          label: "Bio",
          name: "bio",
          type: "textarea",
          rows: 4,
          value: userProfile.bio || "",
          helpText: "A short bio about your reading habits or favorite genres."
        }) %>

        <%- include("partials/form-field", {
          label: "Avatar URL",
          name: "avatar_url",
          value: userProfile.avatar_url || "",
          helpText: "Paste a direct link to an image to use as your avatar."
        }) %>

      </section>

      <div class="form-actions">
        <button class="btn btn-primary" type="submit">
          <i data-lucide="save" aria-hidden="true"></i>
          Save Settings
        </button>
      </div>

    </form>

  </section>

</main>

<%- include("partials/footer") %>
