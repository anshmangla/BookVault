<%- include("partials/header") %>

<main class="auth-shell">

  <section class="surface-card auth-card" aria-labelledby="register-title">

    <header class="auth-card-header">
      <span class="page-header-eyebrow">
        <i data-lucide="library-big" aria-hidden="true"></i>
        Start your library
      </span>
      <h1 id="register-title">Create your account</h1>
      <p>Keep your books, notes, reviews, and reading history together.</p>
    </header>

    <form action="/register" method="POST">

      <%- include("partials/form-field", {
        label: "Username",
        name: "username",
        autocomplete: "username",
        fieldRequired: true
      }) %>

      <%- include("partials/form-field", {
        label: "Email",
        name: "email",
        type: "email",
        autocomplete: "email",
        fieldRequired: true
      }) %>

      <%- include("partials/form-field", {
        label: "Password",
        name: "password",
        type: "password",
        autocomplete: "new-password",
        helpText: "Use a password you do not reuse on other websites.",
        fieldRequired: true
      }) %>

      <button class="btn btn-primary w-100" type="submit">
        Create account
      </button>

    </form>

    <p class="auth-footer">
      Already have an account?
      <a href="/login">Log in</a>
    </p>

  </section>

</main>

<%- include("partials/footer") %>
