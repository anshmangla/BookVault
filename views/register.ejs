<%- include("partials/header") %>

<main class="auth-shell">

  <section class="surface-card auth-card" aria-labelledby="register-title">

    <header class="auth-card-header">
      <span class="page-header-eyebrow">
        <i data-lucide="library-big" aria-hidden="true"></i>
        Start your library
      </span>
      <h1 id="register-title">Create your account</h1>
      <p>Keep your books, notes, reviews, and reading history together.</p>
    </header>

    <% if (typeof error !== "undefined" && error) { %>
      <%- include("partials/alert", {
        alertType: "danger",
        alertMessage: error
      }) %>
    <% } %>

    <div class="auth-social" style="margin-bottom: 2rem;">
      <a href="/auth/google" class="btn btn-secondary w-100" style="display: flex; justify-content: center; align-items: center; gap: 0.5rem;">
        <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
          <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
          <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
          <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
          <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
        </svg>
        Continue with Google
      </a>
    </div>

    <div class="auth-divider" style="display: flex; align-items: center; margin-bottom: 2rem; color: var(--text-light); font-size: 0.875rem;">
      <div style="flex-grow: 1; height: 1px; background: var(--border);"></div>
      <span style="padding: 0 1rem;">OR</span>
      <div style="flex-grow: 1; height: 1px; background: var(--border);"></div>
    </div>

    <form action="/register" method="POST">

      <%- include("partials/form-field", {
        label: "Username",
        name: "username",
        value: typeof username !== "undefined" ? username : "",
        autocomplete: "username",
        fieldRequired: true
      }) %>

      <%- include("partials/form-field", {
        label: "Email",
        name: "email",
        type: "email",
        value: typeof email !== "undefined" ? email : "",
        autocomplete: "email",
        fieldRequired: true
      }) %>

      <%- include("partials/form-field", {
        label: "Password",
        name: "password",
        type: "password",
        autocomplete: "new-password",
        helpText: "Must be at least 8 characters long. Use a password you do not reuse on other websites.",
        fieldRequired: true
      }) %>

      <button class="btn btn-primary w-100" type="submit">
        Create account
      </button>

    </form>

    <p class="auth-footer">
      Already have an account?
      <a href="/login">Log in</a>
    </p>

  </section>

</main>

<%- include("partials/footer") %>
