<%- include("partials/header") %>

<div class="card shadow p-4">

  <div class="row">

    <div class="col-md-4">

      <img
        src="<%= book.cover_url %>"
        class="img-fluid rounded"
      >

    </div>

    <div class="col-md-8">

      <h1>
        <%= book.title %>
      </h1>

      <h5 class="text-muted">
        <%= book.author %>
      </h5>

      <hr>

      <p>

        <strong>
          Rating:
        </strong>

        ⭐ <%= book.rating || "N/A" %>

      </p>

      <p>

        <strong>
          ISBN:
        </strong>

        <%= book.isbn || "N/A" %>

      </p>

      <p>

        <strong>
          Publish Year:
        </strong>

        <%= book.publish_year || "N/A" %>

      </p>

      <p>

        <strong>
          Date Read:
        </strong>

        <%= book.date_read
        ? new Date(book.date_read)
        .toLocaleDateString()
        : "N/A" %>

      </p>

    </div>

  </div>

</div>

<div class="card shadow mt-4 p-4">

  <h3>
    Notes
  </h3>

  <p>

    <%= book.notes || "No notes." %>

  </p>

</div>

<div class="card shadow mt-4 p-4">

  <h3>
    Review
  </h3>

  <p>

    <%= book.review || "No review." %>

  </p>

</div>

<div class="mt-4">

  <a
    href="/edit/<%= book.id %>"
    class="btn btn-warning"
  >

    Edit

  </a>

  <a
    href="/"
    class="btn btn-secondary"
  >

    Back

  </a>

</div>

<%- include("partials/footer") %>