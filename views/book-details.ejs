<%- include("partials/header") %>

<main class="page-shell">

  <%- include("partials/page-header", {
    eyebrow: "Your library",
    icon: "book-open",
    title: book.title,
    description: [
      book.subtitle,
      book.author
        ? `By ${book.author}`
        : "Author not available"
    ].filter(Boolean).join(" · ")
  }) %>

  <%- include("partials/action-toast") %>

  <div class="book-detail-actions" aria-label="Book actions">
    <a href="/edit/<%= book.id %>" class="btn btn-primary">
      <i data-lucide="pencil" aria-hidden="true"></i>
      Edit Book
    </a>

    <form
      action="/delete/<%= book.id %>?_method=DELETE"
      method="POST"
      data-confirm-form
      data-confirm-title="Remove <%= book.title %>?"
      data-confirm-message="Remove “<%= book.title %>” from your library? You can undo this from the next screen."
      data-confirm-label="Remove Book">
      <button class="btn btn-danger-ghost" type="submit">
        <i data-lucide="trash-2" aria-hidden="true"></i>
        Delete
      </button>
    </form>
  </div>

  <section class="surface-card book-detail-card">

    <%- include("partials/book-cover", {
      book,
      coverClass: "book-detail-cover",
      eager: true
    }) %>

    <div class="book-detail-metadata">

      <dl>
        <div>
          <dt>Rating</dt>
          <dd><%= book.rating ? `${book.rating}/10` : "Not rated" %></dd>
        </div>

        <div>
          <dt>ISBN</dt>
          <dd><%= book.isbn || "Not available" %></dd>
        </div>

        <div>
          <dt>Publication year</dt>
          <dd><%= book.publish_year || "Not available" %></dd>
        </div>

        <% if (book.published_date) { %>
          <div>
            <dt>Published</dt>
            <dd><%= book.published_date %></dd>
          </div>
        <% } %>

        <% if (book.publisher) { %>
          <div>
            <dt>Publisher</dt>
            <dd><%= book.publisher %></dd>
          </div>
        <% } %>

        <% if (book.page_count) { %>
          <div>
            <dt>Length</dt>
            <dd><%= book.page_count %> pages</dd>
          </div>
        <% } %>

        <% if (book.language) { %>
          <div>
            <dt>Language</dt>
            <dd><%= book.language.toUpperCase() %></dd>
          </div>
        <% } %>

        <div>
          <dt>Date read</dt>
          <dd>
            <%= book.date_read
              ? new Date(book.date_read).toLocaleDateString()
              : "Not recorded" %>
          </dd>
        </div>
      </dl>

      <% if (
        Array.isArray(book.categories) &&
        book.categories.length
      ) { %>
        <div class="book-category-list" aria-label="Categories">
          <% book.categories.forEach(category => { %>
            <span><%= category %></span>
          <% }) %>
        </div>
      <% } %>

    </div>

  </section>

  <div class="book-detail-sections">

    <% if (book.description) { %>

      <section class="surface-card book-text-section book-description-section">
        <h2>About this book</h2>
        <p class="book-description"><%= book.description %></p>
      </section>

    <% } %>

    <section class="surface-card book-text-section">
      <h2>Notes</h2>
      <p class="<%= book.notes ? "reader-prose" : "empty-copy" %>"><%= book.notes || "No notes added yet." %></p>
    </section>

    <section class="surface-card book-text-section">
      <h2>Review</h2>
      <p class="<%= book.review ? "reader-prose" : "empty-copy" %>"><%= book.review || "No review added yet." %></p>
    </section>

  </div>

  <a href="/" class="btn btn-secondary">
    <i data-lucide="arrow-left" aria-hidden="true"></i>
    Back to Library
  </a>

</main>

<%- include("partials/footer") %>
