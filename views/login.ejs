<%- include("partials/header") %>

<div class="row justify-content-center">

  <div class="col-md-6">

    <div class="card shadow p-4">

      <h2 class="mb-4 text-center">
        Login
      </h2>

      <form action="/login" method="POST">

        <div class="mb-3">

          <label class="form-label">
            Email
          </label>

          <input
            type="email"
            name="email"
            class="form-control"
            required
          >

        </div>

        <div class="mb-3">

          <label class="form-label">
            Password
          </label>

          <input
            type="password"
            name="password"
            class="form-control"
            required
          >

        </div>

        <button
          class="btn btn-primary w-100"
          type="submit"
        >
          Login
        </button>
        <hr>

        <a
        href="/auth/google"
        class="
        btn
        btn-danger
        w-100">

        Continue with Google

        </a>

      </form>

      <hr>

      <p class="text-center">

        Don't have an account?

        <a href="/register">
          Register
        </a>

      </p>

    </div>

  </div>

</div>

<%- include("partials/footer") %>