<%- include("partials/header") %>

<main class="auth-shell">

  <section class="surface-card auth-card" aria-labelledby="login-title">

    <header class="auth-card-header">
      <span class="page-header-eyebrow">
        <i data-lucide="book-open" aria-hidden="true"></i>
        Welcome back
      </span>
      <h1 id="login-title">Log in to BookVault</h1>
      <p>Continue building your personal reading library.</p>
    </header>

    <% if (typeof error !== "undefined" && error) { %>
      <%- include("partials/alert", {
        alertType: "danger",
        alertMessage: error
      }) %>
    <% } %>

    <form action="/login" method="POST">

      <%- include("partials/form-field", {
        label: "Username or Email",
        name: "identifier",
        type: "text",
        value: typeof identifier !== "undefined" ? identifier : "",
        autocomplete: "username",
        fieldRequired: true
      }) %>

      <%- include("partials/form-field", {
        label: "Password",
        name: "password",
        type: "password",
        autocomplete: "current-password",
        fieldRequired: true
      }) %>

      <button class="btn btn-primary w-100" type="submit">
        Log in
      </button>

    </form>

    <div class="auth-divider">or</div>

    <a href="/auth/google" class="btn btn-light w-100">
      <i data-lucide="log-in" aria-hidden="true"></i>
      Continue with Google
    </a>

    <p class="auth-footer">
      Don’t have an account?
      <a href="/register">Create one</a>
    </p>

  </section>

</main>

<%- include("partials/footer") %>
