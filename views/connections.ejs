<%- include("partials/header") %>

<main class="page-shell">

  <%- include("partials/page-header", {
    eyebrow: "Connections",
    icon: "users",
    title: profileUser.username,
    description: "View followers and following."
  }) %>

  <div class="connections-tabs" style="display: flex; justify-content: center; gap: 2rem; margin-bottom: 2rem; border-bottom: 1px solid var(--border);">
    <a href="/u/<%= profileUser.username %>/followers" 
       style="padding: 1rem; text-decoration: none; font-weight: 600; color: <%= activeTab === 'followers' ? 'var(--primary)' : 'var(--text-light)' %>; border-bottom: 3px solid <%= activeTab === 'followers' ? 'var(--primary)' : 'transparent' %>;">
      Followers
    </a>
    <a href="/u/<%= profileUser.username %>/following" 
       style="padding: 1rem; text-decoration: none; font-weight: 600; color: <%= activeTab === 'following' ? 'var(--primary)' : 'var(--text-light)' %>; border-bottom: 3px solid <%= activeTab === 'following' ? 'var(--primary)' : 'transparent' %>;">
      Following
    </a>
  </div>

  <section class="container" style="max-width: 800px; margin: 0 auto;">
    <% if (users.length === 0) { %>
      <%- include("partials/empty-state", {
        icon: "users-round",
        title: activeTab === 'followers' ? "No followers yet" : "Not following anyone",
        description: activeTab === 'followers' ? "This user doesn't have any followers." : "This user isn't following anyone.",
        actionHref: null
      }) %>
    <% } else { %>
      <div class="user-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.5rem;">
        <% users.forEach(user => { %>
          <div class="surface-card user-card" style="padding: 1.5rem; text-align: center;">
            <a href="/u/<%= user.username %>" style="display: block; text-decoration: none; color: inherit; margin-bottom: 1rem;">
              <% if (user.avatar_url) { %>
                <img src="<%= user.avatar_url %>" alt="" style="width: 80px; height: 80px; border-radius: 50%; object-fit: cover; margin-bottom: 1rem; border: 2px solid var(--border);">
              <% } else { %>
                <div style="width: 80px; height: 80px; border-radius: 50%; background: var(--primary-soft); color: var(--primary); display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem auto;">
                  <i data-lucide="user" style="width: 32px; height: 32px;"></i>
                </div>
              <% } %>
              <h3 style="font-size: 1.2rem; margin-bottom: 0.5rem;"><%= user.username %></h3>
              <% if (user.bio) { %>
                <p style="font-size: 0.9rem; color: var(--text-light); display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;"><%= user.bio %></p>
              <% } %>
            </a>
            
            <% if (userId && userId !== user.id) { %>
              <button 
                type="button" 
                class="btn follow-btn <%= user.is_following ? 'btn-secondary' : 'btn-primary' %>" 
                data-username="<%= user.username %>"
                style="width: 100%;">
                <i data-lucide="<%= user.is_following ? 'user-minus' : 'user-plus' %>" aria-hidden="true"></i>
                <span><%= user.is_following ? 'Unfollow' : 'Follow' %></span>
              </button>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>
  </section>

</main>

<script>
  document.querySelectorAll('.follow-btn').forEach(btn => {
    btn.addEventListener("click", async () => {
      const username = btn.getAttribute("data-username");
      const res = await fetch(`/u/${username}/follow`, { method: "POST" });
      if (res.ok) {
        const data = await res.json();
        const btnSpan = btn.querySelector("span");
        const icon = btn.querySelector("i");
        
        if (data.is_following) {
          btn.classList.replace("btn-primary", "btn-secondary");
          btnSpan.textContent = "Unfollow";
          icon.setAttribute("data-lucide", "user-minus");
        } else {
          btn.classList.replace("btn-secondary", "btn-primary");
          btnSpan.textContent = "Follow";
          icon.setAttribute("data-lucide", "user-plus");
        }
        lucide.createIcons();
      }
    });
  });
</script>

<%- include("partials/footer") %>
